rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "mohammedshehu985@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Global deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'points', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.points is number &&
             data.role in ['student', 'admin'] &&
             data.createdAt is timestamp &&
             (data.role == 'admin' || (
               data.keys().hasAll(['hasPaid', 'paymentReference', 'registrationFee', 'paymentStatus']) &&
               data.hasPaid is bool &&
               data.paymentStatus in ['pending', 'approved', 'rejected'] &&
               data.paymentReference is string &&
               data.registrationFee >= 0
             ));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'student' && incoming().points == 0;
      allow update: if (isAdmin() || (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['bio', 'displayName']))) && isValidUser(incoming());
    }

    // --- Courses ---
    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'category', 'description', 'thumbnail']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category in ["Mathematics", "Science", "Mechanical Engineering", "ICT", "Bible Study"] &&
             data.description is string && data.description.size() <= 2000;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidCourse(incoming());
    }

    // --- Lessons ---
    function isValidLesson(data) {
      return data.keys().hasAll(['courseId', 'title', 'content', 'order', 'createdAt']) &&
             data.courseId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.order is number &&
             (data.videoUrl == "" || data.videoUrl is string) &&
             (data.pdfUrl == "" || data.pdfUrl is string) &&
             data.createdAt is timestamp;
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin() && isValidLesson(incoming());
    }

    // --- Quizzes ---
    function isValidQuiz(data) {
      return data.keys().hasAll(['lessonId', 'questions']) &&
             data.lessonId is string &&
             data.questions is list && data.questions.size() <= 50;
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidQuiz(incoming());
    }

    // --- Quiz Results ---
    function isValidResult(data) {
      return data.keys().hasAll(['userId', 'quizId', 'score', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.score is number &&
             data.timestamp == request.time;
    }

    match /quiz_results/{resultId} {
      allow read: if isSignedIn(); // For leaderboards
      allow create: if isSignedIn() && isValidResult(incoming());
      allow update, delete: if isAdmin();
    }

    // --- Topic Requests ---
    match /requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // --- Quotes ---
    match /quotes/{quoteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
